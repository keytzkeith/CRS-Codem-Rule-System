# =============================================================================
# CRS Production Environment Configuration
# =============================================================================
# Copy this file to backend/.env on your production server and replace values.
# Do not commit real secrets.

# =============================================================================
# CORE APPLICATION
# =============================================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=INFO
ENABLE_SWAGGER=false
RUN_MIGRATIONS=true

# =============================================================================
# DATABASE
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=crs_user
DB_PASSWORD=replace_with_real_password
DB_NAME=crs_production

# =============================================================================
# AUTH AND SECURITY
# =============================================================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_EXPIRE=7d
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=30d
DETAILED_AUTH_ERRORS=false

# Registration modes:
# - open
# - approval
# - disabled
REGISTRATION_MODE=approval

# =============================================================================
# URLS AND CORS
# =============================================================================
FRONTEND_URL=https://crs.yourdomain.com
PUBLIC_APP_URL=https://crs.yourdomain.com
DOCS_SITE_URL=https://docs.yourdomain.com
PRIVACY_URL=https://crs.yourdomain.com/privacy
TERMS_URL=https://crs.yourdomain.com/terms
CORS_ORIGINS=https://crs.yourdomain.com,https://docs.yourdomain.com
API_BASE_URL=https://crs.yourdomain.com

# =============================================================================
# EMAIL
# =============================================================================
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_DOMAIN=yourdomain.com
SUPPORT_EMAIL=oderakeith@gmail.com
DKIM_PRIVATE_KEY=
DKIM_SELECTOR=default

# =============================================================================
# BILLING
# =============================================================================
# Keep false unless you are intentionally enabling subscription billing.
BILLING_ENABLED=false
FEATURES_BILLING_ENABLED=false

# =============================================================================
# EXTERNAL APIS
# =============================================================================
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
OPENFIGI_API_KEY=
COINGECKO_API_KEY=

# =============================================================================
# OPTIONAL ENCRYPTION / OAUTH
# =============================================================================
BROKER_ENCRYPTION_KEY=
OAUTH_PRIVATE_KEY=
OAUTH_PRIVATE_KEY_PATH=
OAUTH_PUBLIC_KEY=
OAUTH_PUBLIC_KEY_PATH=
APPLE_APP_BUNDLE_ID=
ANDROID_PACKAGE_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_PRICE_MONITORING=false
ENABLE_TRADE_ENRICHMENT=false
ENABLE_JOB_RECOVERY=false
ENABLE_GAMIFICATION=false
ENABLE_TRIAL_EMAILS=false
ENABLE_OPTIONS_SCHEDULER=false
ENABLE_BACKUP_SCHEDULER=true
ENABLE_ENRICHMENT_CACHE_CLEANUP=false
ENABLE_BROKER_SYNC_SCHEDULER=false
ENABLE_DIVIDEND_SCHEDULER=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_AI_CUSIP_RESOLUTION=false

# =============================================================================
# FILES AND RATE LIMITS
# =============================================================================
MAX_FILE_SIZE=52428800
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000

# =============================================================================
# APP INSTANCE IDENTITY
# =============================================================================
INSTANCE_NAME=CRS
INSTANCE_URL=https://crs.yourdomain.com
